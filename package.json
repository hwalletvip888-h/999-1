{
  "name": "h-wallet-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "dev:wallet-backend": "AGENT_WALLET_PROVIDER=http npx tsx src/services/walletBackend.ts",
    "dev:wallet-backend-cli": "npx tsx src/services/walletBackend.ts",
    "dev:expo-lan": "bash scripts/start-expo-lan.sh",
    "dev:expo-remote": "bash scripts/start-expo-remote-backend.sh",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "eas:update:production": "eas update --channel production --non-interactive",
    "build:apk:preview": "eas build --platform android --profile preview --non-interactive",
    "deploy:remote": "bash deploy/remote-deploy.sh",
    "github:bootstrap": "bash deploy/gh-actions-bootstrap.sh",
    "deploy:init": "bash deploy/init-local-env.sh",
    "deploy:readme": "node -e \"require('fs').createReadStream('deploy/START_HERE.md').pipe(process.stdout)\"",
    "bootstrap:subpkgs": "npm install --prefix h1-platform && npm install --prefix mcp-hwallet-server",
    "test:h1": "npm install --prefix h1-platform && npm test --prefix h1-platform",
    "test:services": "vitest run --config vitest.services.config.ts",
    "security:audit": "npm audit",
    "mcp:hwallet": "npm install --prefix mcp-hwallet-server && npm run dev --prefix mcp-hwallet-server",
    "mcp:hwallet:build": "npm run build --prefix mcp-hwallet-server"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.7",
    "expo-clipboard": "~8.0.8",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.7",
    "expo-media-library": "~18.2.1",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-updates": "~29.0.17",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-markdown-display": "^7.0.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "latest",
    "@types/react": "latest",
    "babel-preset-expo": "latest",
    "eas-cli": "^18.11.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "tar": "^7.5.15",
    "@xmldom/xmldom": "^0.9.10",
    "postcss": "^8.5.10",
    "eas-cli": {
      "ajv": "^8.20.0",
      "diff": "^9.0.0",
      "minimatch": "5.1.8",
      "node-forge": "^1.4.0",
      "yaml": "^2.8.4"
    },
    "react-native-markdown-display": {
      "markdown-it": "^12.3.2"
    }
  }
}

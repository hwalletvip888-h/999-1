# 复制为 local-server.env（已被 .gitignore）后填写；勿在仓库中保存 GitHub PAT 或 SSH 私钥正文。
# cp deploy/local-server.env.example deploy/local-server.env

# ─── GitHub Actions 一键写入 Secrets/Variables（在本机执行）────────────────
#   brew install gh && gh auth login
#   bash deploy/gh-actions-bootstrap.sh
# 可选：export EXPO_TOKEN=... 再运行同一脚本，会写入 EXPO_TOKEN 并打开 ENABLE_EAS_OTA

# ─── 目标仓库（gh-actions-bootstrap.sh 必填）──────────────────────────────
GITHUB_REPOSITORY=owner/repo

# ─── SSH / 跳板 ───────────────────────────────────────────────────────────
DEPLOY_HOST=
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_PROJECT_DIR=/opt/h-wallet
# 用于 gh secret set DEPLOY_SSH_KEY；默认 ~/.ssh/id_ed25519
# DEPLOY_SSH_PRIVATE_KEY_FILE=~/.ssh/id_ed25519_github_actions

# 仅限本机；配合 mac-push-and-bootstrap.sh，需 brew install esolitos/sshpass/sshpass
# DEPLOY_SSH_PASSWORD=

# ─── 人类运营台（/ops + /api/admin/*）────────────────────────────────────
# 强随机字符串；仅运维人员配置在服务器环境变量，勿提交仓库
# HWALLET_OPS_ADMIN_TOKEN=

# ─── 服务器上跑 walletBackend / 网关时可能需要 ─────────────────
WALLET_PORT=3100
AGENT_WALLET_PROVIDER=http
OKX_BASE_URL=https://web3.okx.com

# ─── 手机端 Expo（打包或 .env.production）里最终要指向的 API ─────────
# EXPO_PUBLIC_HWALLET_API_BASE=http://你的公网IP:3100
# 或：https://wallet-api.你的域名.com

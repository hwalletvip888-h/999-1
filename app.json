{
  "expo": {
    "name": "H Wallet",
    "slug": "h-wallet-mvp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "hwallet",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#7C3AED",
      "resizeMode": "contain"
    },
    "web": {
      "bundler": "metro"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.hwallet.app",
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      },
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 1
    },
    "ios": {
      "bundleIdentifier": "com.hwallet.app",
      "buildNumber": "1"
    },
    "extra": {
      "eas": {
        "projectId": "fce2e5cc-b9c0-446b-ae18-446ce1c74199"
      }
    },
    "plugins": [
      "expo-font"
    ],
    "owner": "hwalletvip"
  }
}
